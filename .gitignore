out/
next-env.d.ts
*.tsbuildinfo

# ─── Other build outputs ────────────────────────────────────────────────────
/build
/dist
.cache/
.turbo/

# ─── Environment files (NEVER commit these) ─────────────────────────────────
.env
.env.local
.env.development
.env.development.local
.env.test
.env.test.local
.env.production
.env.production.local
# .env.example IS committed — it's the template

