*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ─── Package manager lockfiles (only pnpm-lock.yaml is canonical) ───────────
package-lock.json
yarn.lock

# ─── Testing / coverage ─────────────────────────────────────────────────────
/coverage
*.lcov

# ─── IDE / editor ───────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.history/

